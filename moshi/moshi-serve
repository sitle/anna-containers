#!/bin/bash
set -e

HF_REPO="${1:-kyutai/moshiko-pytorch-bf16}"

echo "=== Moshi Server ==="
echo "Model:    $HF_REPO"
echo "Backend:  http://127.0.0.1:8998 (internal)"
echo "Proxy:    http://0.0.0.0:8080 (requires API_KEY)"
echo "====================="

# Start Caddy reverse proxy in background
export BACKEND_PORT=8998
if [ -n "$API_KEY" ]; then
    start-proxy &
    echo "Caddy proxy started on :8080"
else
    echo "WARNING: No API_KEY set, proxy disabled."
fi

# Start Moshi server on localhost only
exec python -m moshi.server \
    --host 127.0.0.1 \
    --port 8998 \
    --hf-repo "$HF_REPO"
