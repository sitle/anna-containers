#!/bin/bash
set -e

MODEL="${1:?Usage: sglang-serve <model-path-or-hf-id> [quantization] [tool-call-parser]}"
QUANT="${2:-awq_marlin}"
PARSER="${3:-hermes}"

echo "=== SGLang Server ==="
echo "Model:    $MODEL"
echo "Quant:    $QUANT"
echo "Parser:   $PARSER"
echo "Backend:  http://127.0.0.1:8000 (internal)"
echo "Proxy:    http://0.0.0.0:8080 (requires API_KEY)"
echo "===================="

# Start Caddy reverse proxy in background
export BACKEND_PORT=8000
if [ -n "$API_KEY" ]; then
    start-proxy &
    echo "Caddy proxy started on :8080"
else
    echo "WARNING: No API_KEY set, proxy disabled. Backend not exposed."
fi

# Start SGLang on localhost only
exec python -u -m sglang.launch_server \
    --model-path "$MODEL" \
    --port 8000 \
    --host 127.0.0.1 \
    --quantization "$QUANT" \
    --dtype auto \
    --tool-call-parser "$PARSER"
