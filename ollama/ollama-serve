#!/bin/bash
set -e

MODEL="${1:?Usage: ollama-serve <model-name> (e.g. qwen2.5-coder:32b)}"

echo "=== Ollama Server ==="
echo "Model:    $MODEL"
echo "Backend:  http://127.0.0.1:11434 (internal)"
echo "Proxy:    http://0.0.0.0:8080 (requires API_KEY)"
echo "====================="

# Start Caddy reverse proxy in background
export BACKEND_PORT=11434
if [ -n "$API_KEY" ]; then
    start-proxy &
    echo "Caddy proxy started on :8080"
else
    echo "WARNING: No API_KEY set, proxy disabled. Backend not exposed."
fi

# Start Ollama on localhost only
OLLAMA_HOST="127.0.0.1:11434" ollama serve &
OLLAMA_PID=$!

# Wait for server to be ready
echo "Waiting for Ollama to start..."
for i in $(seq 1 30); do
    if curl -s "http://127.0.0.1:11434/api/tags" > /dev/null 2>&1; then
        echo "Ollama ready."
        break
    fi
    sleep 1
done

# Pull the model
echo "Pulling model: $MODEL ..."
ollama pull "$MODEL"
echo "Model ready. API available via proxy on :8080"

# Keep running
wait $OLLAMA_PID
